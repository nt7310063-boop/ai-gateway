# flowgrok — environment template. Copy to `.env` and fill secrets.
#
# Generate strong values:
#   openssl rand -hex 16    → POSTGRES_PASSWORD
#   openssl rand -hex 32    → JWT_SECRET
#   openssl rand -hex 16    → ENCRYPTION_KEY
#
# Required
POSTGRES_PASSWORD=
JWT_SECRET=
ENCRYPTION_KEY=
PUBLIC_DOMAIN=editor.example.com

# Optional — public-facing API URL the FE bakes into its bundle.
# Defaults to https://${PUBLIC_DOMAIN}. Override only if you front
# the app with a CDN/proxy on a different hostname.
# PUBLIC_API_URL=https://api.editor.example.com

# Optional — DB / Redis names (sane defaults)
POSTGRES_USER=flowgrok
POSTGRES_DB=flowgrok

# Optional — perf tuning
GUNICORN_WORKERS=2
IDLE_CLEANUP_HOURS=2
IDLE_CLEANUP_INTERVAL=900
FRONTEND_HOST_PORT=5173

# Optional — email (password reset, webhook delivery notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional — host SSH (if you want the admin "Heal infra" button to
# work; lets the backend container restart the host's nginx-reload
# watcher when it dies). Leave blank to disable the feature.
HOST_SSH_HOST=host.docker.internal
HOST_SSH_PORT=22
HOST_SSH_USER=
HOST_SSH_PASSWORD=
